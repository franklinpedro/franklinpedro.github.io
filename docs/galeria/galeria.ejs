| Olympus Stylus (Mju I) | Fujifilm 400</div>

<div class="grid-gallery" id="galeria-grid"></div>

<script>
function iniciarGaleria() {
  var raw   = document.getElementById('galeria-raw').innerText.trim();
  var fotos = raw.split(';;;');
  var grid  = document.getElementById('galeria-grid');

  fotos.forEach(function (entry) {
    entry = entry.trim();
    if (!entry) return;
    var parts = entry.split('||');
    var file  = parts[0].trim();
    var title = (parts[1] || '').trim();

    var a = document.createElement('a');
    a.href = file;
    a.setAttribute('data-lightbox', 'galeria');
    a.setAttribute('data-title', title);
    a.className = 'grid-item-wrap';

    var img       = document.createElement('img');
    img.src       = 'thumbs/' + file;
    img.className = 'grid-item';
    img.loading   = 'lazy';
    img.alt       = title;

    a.appendChild(img);
    grid.appendChild(a);
  });

  lightbox.option({
    resizeDuration : 300,
    wrapAround     : true,
    fadeDuration   : 300,
    positionFromTop: 100,
    albumLabel     : 'Imagem %1 de %2'
  });
}

function carregarScript(src, cb) {
  var s    = document.createElement('script');
  s.src    = src;
  s.onload = cb;
  document.head.appendChild(s);
}

document.addEventListener('DOMContentLoaded', function () {
  carregarScript('jquery.slim.min.js', function () {
    carregarScript('lightbox.min.js', function () {
      iniciarGaleria();
    });
  });
});
</script>
